{
  "buildCommand": "pip install -r requirements.txt",
  "framework": "streamlit",
  "public": true,
  "env": {
    "STREAMLIT_SERVER_HEADLESS": "true",
    "STREAMLIT_SERVER_PORT": "8501",
    "STREAMLIT_SERVER_RUNONSAVE": "false",
    "STREAMLIT_CLIENT_SHOWERRORDETAILS": "false"
  },
  "functions": {
    "api/index.py": {
      "memory": 3008,
      "maxDuration": 900
    }
  }
}
